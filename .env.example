# Copy to `.env` for local dev, or set the same keys in EAS / your CI.
# Never commit real keys.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: baked in at EAS build time (see `app.config.js` → `extra.gitCommit`).
# EXPO_PUBLIC_GIT_COMMIT=abc1234

# Dev parity: allow demo@demo.com auto sign-up when login fails (matches Metro __DEV__).
# Default off in production EAS profile; `eas.json` preview profile sets this to true.
# EXPO_PUBLIC_ENABLE_DEMO_AUTH_HELPER=true

# Show Settings → “Diagnostics” and verbose `[twoforone:boot]` log (set EXPO_PUBLIC_DEBUG_BOOT_LOG too).
# EXPO_PUBLIC_SHOW_DEBUG_PANEL=true
# EXPO_PUBLIC_DEBUG_BOOT_LOG=true

# Mark build as “Expo-dev-like” in Diagnostics (EAS preview/development profiles set this in eas.json).
# EXPO_PUBLIC_PREVIEW_MATCHES_DEV=true

# Public website (legal & support). Defaults use https://www.twofer.app/... if unset.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.twofer.app/privacy
# EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://www.twofer.app/terms
# EXPO_PUBLIC_SUPPORT_URL=https://www.twofer.app/support
# EXPO_PUBLIC_DELETE_ACCOUNT_URL=https://www.twofer.app/delete-account

# Legal (in-app links; host real pages before store review)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.twofer.app/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://www.twofer.app/terms

# AI runs in Supabase Edge (not in the Expo app). In Supabase Dashboard:
# Project Settings → Edge Functions → Secrets
#
# Required for real GPT on non-demo users:
#   OPENAI_API_KEY=sk-...
#
# Optional:
#   OPENAI_MODEL=gpt-5.4-mini   # recommended; allowed: gpt-4o-mini, gpt-5.4-mini, gpt-5.4-nano, gpt-5.4
#   OPENAI_WHISPER_MODEL=whisper-1   # only if you override Whisper (ai-compose-offer)
#   AI_ADS_DEMO_USE_LIVE=true   # use OpenAI for demo@demo.com (default is template ads)
#
# Edge functions used by the app (deploy all that exist in `supabase/functions/`):
#   claim-deal, redeem-token, begin-visual-redeem, complete-visual-redeem, cancel-visual-redeem,
#   finalize-stale-redeems, delete-user-account, ingest-analytics-event, …
#
# Edge functions used by the app:
#   ai-compose-offer        — AI compose + optional voice (uses same OPENAI_MODEL for chat)
#   ai-generate-ad-variants — main “3 ad ideas” flow (photo and/or structured menu offer)
#   ai-extract-menu         — menu photo → items (OpenAI Responses API + vision)
#   ai-refine-ad-copy       — chat-style edits to a selected ad draft
#   ai-generate-deal-copy   — Quick Deal “Suggest title (AI)”
#   ai-create-deal          — legacy one-shot insert (dev test button on AI ads screen only)
