# Copy to `.env` for local dev, or set the same keys in EAS / your CI.
# Never commit real keys.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: baked in at EAS build time (see `app.config.js` → `extra.gitCommit`).
# EXPO_PUBLIC_GIT_COMMIT=abc1234

# Show Settings → “Diagnostics” and verbose `[twoforone:boot]` log (set EXPO_PUBLIC_DEBUG_BOOT_LOG too).
# EXPO_PUBLIC_SHOW_DEBUG_PANEL=true
# EXPO_PUBLIC_DEBUG_BOOT_LOG=true

# Google Maps API key for Android (required for map tab).
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=AIza...

# Mark build as “Expo-dev-like” in Diagnostics (EAS preview/development profiles set this in eas.json).
# EXPO_PUBLIC_PREVIEW_MATCHES_DEV=true

# Public website (legal & support). Defaults use https://www.twoferapp.com/... if unset.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.twoferapp.com/privacy
# EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://www.twoferapp.com/terms
# EXPO_PUBLIC_SUPPORT_URL=https://www.twoferapp.com/support
# EXPO_PUBLIC_DELETE_ACCOUNT_URL=https://www.twoferapp.com/delete-account

# Legal (in-app links; pages live at https://www.twoferapp.com)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.twoferapp.com/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://www.twoferapp.com/terms

# AI runs in Supabase Edge (not in the Expo app). In Supabase Dashboard:
# Project Settings → Edge Functions → Secrets
#
# Required for GPT-backed AI features:
#   OPENAI_API_KEY=sk-...
#
# Optional:
#   OPENAI_MODEL=gpt-4o-mini   # safe default; leave UNSET to use gpt-4o-mini. Only set gpt-5.4* if your OpenAI account actually has them.
#   OPENAI_WHISPER_MODEL=whisper-1   # only if you override Whisper (ai-compose-offer)
# Image generation (Supabase Edge secrets — see _shared/dalle-image.ts allowlist):
#   OPENAI_IMAGE_MODEL_DEFAULT=gpt-image-1
#   OPENAI_IMAGE_MODEL_GENERATE=gpt-image-1
#   OPENAI_IMAGE_MODEL_EDIT=gpt-image-1
#
# Edge functions used by the app (deploy all that exist in `supabase/functions/`):
#   claim-deal, redeem-token, begin-visual-redeem, complete-visual-redeem, cancel-visual-redeem,
#   finalize-stale-redeems, delete-user-account, ingest-analytics-event, …
#
# Edge functions used by the app (representative; see `supabase/config.toml` and deploy all in use):
#   ai-compose-offer        — AI compose + optional voice (uses same OPENAI_MODEL for chat)
#   ai-generate-ad-variants — single-ad pipeline (research → copy → image; photo and/or hint)
#   ai-extract-menu         — menu photo → items (OpenAI Responses API + vision)
#   ai-business-lookup      — Google Places + optional AI estimate
#   ai-generate-deal-copy   — text deal copy suggestions
#   ai-create-deal          — legacy one-shot insert (dev-only / secondary)
#   Plus claim/redeem, analytics, billing/Stripe helpers, push, account deletion, etc.
