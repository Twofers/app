# Copy to `.env` for local dev, or set the same keys in EAS / your CI.
# Never commit real keys.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: baked in at EAS build time (see `app.config.js` → `extra.gitCommit`).
# EXPO_PUBLIC_GIT_COMMIT=abc1234

# Show Settings → “Diagnostics” and verbose `[twoforone:boot]` log (set EXPO_PUBLIC_DEBUG_BOOT_LOG too).
# EXPO_PUBLIC_SHOW_DEBUG_PANEL=true
# EXPO_PUBLIC_DEBUG_BOOT_LOG=true

# Google Maps API key for Android (required for map tab).
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=AIza...

# Mark build as “Expo-dev-like” in Diagnostics (EAS preview/development profiles set this in eas.json).
# EXPO_PUBLIC_PREVIEW_MATCHES_DEV=true

# Public website (legal & support). Defaults use https://www.twoferapp.com/... if unset.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.twoferapp.com/privacy
# EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://www.twoferapp.com/terms
# EXPO_PUBLIC_SUPPORT_URL=https://www.twoferapp.com/support
# EXPO_PUBLIC_DELETE_ACCOUNT_URL=https://www.twoferapp.com/delete-account

# Mobile billing / App Store posture. Production builds must keep these false.
# Dev JS may set all five to true only for local Stripe checkout testing.
EXPO_PUBLIC_ENABLE_MOBILE_STRIPE=false
EXPO_PUBLIC_ENABLE_MOBILE_SUBSCRIPTION_CTA=false
EXPO_PUBLIC_ENABLE_BUSINESS_SELF_SERVE_MOBILE=false
EXPO_PUBLIC_ENABLE_MOBILE_PRICING_PAGE=false
EXPO_PUBLIC_ENABLE_MOBILE_BILLING_LINKS=false

# Legal (in-app links; pages live at https://www.twoferapp.com)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.twoferapp.com/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://www.twoferapp.com/terms

# AI runs in Supabase Edge (not in the Expo app). In Supabase Dashboard:
# Project Settings → Edge Functions → Secrets
#
# Required for OpenAI-backed AI features:
#   OPENAI_API_KEY=sk-...
#
# Optional text / voice provider settings:
#   OPENAI_MODEL=gpt-5.5   # default if unset; older allowlisted models are rollback-only.
#   OPENAI_WHISPER_MODEL=whisper-1   # only if you override Whisper (ai-compose-offer)
#   GEMINI_API_KEY=...   # required only when Gemini text, judge, vision QA, or image flags are enabled
#   GEMINI_TEXT_MODEL=gemini-3.5-flash
#   GEMINI_JUDGE_MODEL=gemini-3.5-flash
#
# Optional shared text router / fallback settings:
#   AI_V3_PROVIDER_ROUTER_ENABLED=true
#   AI_TEXT_FALLBACK_ENABLED=false   # keep false in production until the public privacy/subprocessor update is deployed
#   AI_TEXT_PRIMARY_PROVIDER=openai
#   AI_TEXT_FALLBACK_PROVIDER=gemini
#   AI_TEXT_PRIMARY_TIMEOUT_MS=12000
#   AI_TEXT_FALLBACK_TIMEOUT_MS=14000
#   AI_TRANSIENT_RETRY_MAX=1
#   AI_RETRY_AFTER_FULL_TIMEOUT=false
#   AI_CIRCUIT_BREAKER_ENABLED=true
#
# Optional independent judging, vision QA, and cost controls:
#   AI_V3_INDEPENDENT_JUDGE_ENABLED=true
#   AI_VISION_PRIMARY_PROVIDER=gemini   # default gemini (cheap); set openai to run vision QA on OpenAI
#   AI_VISION_FALLBACK_ENABLED=true     # default true; lets the other provider backstop QA on error
#   AI_VISION_PRIMARY_TIMEOUT_MS=25000
#   AI_VISION_FALLBACK_TIMEOUT_MS=14000
#   AI_STOCK_QA_CANDIDATE_LIMIT=3
#   AI_AD_WEB_SEARCH_ENABLED=true       # default true; set false to disable the paid gpt-4o-search-preview item lookup
#   AI_MENU_EXTRACTION_PROVIDER=gemini  # menu OCR provider; default gemini (cheap vision), OpenAI backstops on failure
#   AI_V3_COST_BUDGET_ENABLED=true
#   AI_TEXT_COST_SOFT_LIMIT_USD=0.2
#   AI_TEXT_COST_HARD_LIMIT_USD=0.5
#   AI_TOTAL_GENERATION_COST_HARD_LIMIT_USD=1
#   AI_REVISION_COST_HARD_LIMIT_USD=0.35
#
# Optional multilingual deal foundation flags (default off until reviewer and rollout gates pass):
#   AI_V5_MULTILINGUAL_FOUNDATION_ENABLED=false
#   EXPO_PUBLIC_AI_V5_MULTILINGUAL_FOUNDATION_ENABLED=false
#   AI_V5_LOCALIZED_OFFER_RENDERER_ENABLED=false
#   EXPO_PUBLIC_AI_V5_LOCALIZED_OFFER_RENDERER_ENABLED=false
#   AI_V5_KOREAN_COUNTER_REGISTRY_ENABLED=false
#   EXPO_PUBLIC_AI_V5_KOREAN_COUNTER_REGISTRY_ENABLED=false
#   AI_V5_LOCALIZED_OWNER_UI_ENABLED=false
#   EXPO_PUBLIC_AI_V5_LOCALIZED_OWNER_UI_ENABLED=false
#   AI_V5_CUSTOMER_LOCALE_RESOLUTION_ENABLED=false
#   EXPO_PUBLIC_AI_V5_CUSTOMER_LOCALE_RESOLUTION_ENABLED=false
#   AI_V5_DEAL_LANGUAGE_SWITCH_ENABLED=false
#   EXPO_PUBLIC_AI_V5_DEAL_LANGUAGE_SWITCH_ENABLED=false
#   AI_V5_SOURCE_LOCALE_CREATIVE_ENABLED=false
#   EXPO_PUBLIC_AI_V5_SOURCE_LOCALE_CREATIVE_ENABLED=false
#   AI_V5_PERSUASIVE_TRANSCRATION_ENABLED=false
#   EXPO_PUBLIC_AI_V5_PERSUASIVE_TRANSCRATION_ENABLED=false
#   AI_V5_TRANSLATION_QA_ENABLED=false
#   EXPO_PUBLIC_AI_V5_TRANSLATION_QA_ENABLED=false
#   AI_V5_DETERMINISTIC_LANGUAGE_FALLBACK_ENABLED=false
#   EXPO_PUBLIC_AI_V5_DETERMINISTIC_LANGUAGE_FALLBACK_ENABLED=false
#   AI_V5_LOCALE_PRESENTATION_OVERRIDES_ENABLED=false
#   EXPO_PUBLIC_AI_V5_LOCALE_PRESENTATION_OVERRIDES_ENABLED=false
#   AI_V5_LOCALE_SCREENSHOT_QA_ENABLED=false
#   EXPO_PUBLIC_AI_V5_LOCALE_SCREENSHOT_QA_ENABLED=false
#   AI_V5_AUTOMATIC_VERIFIED_BUNDLE_APPROVAL_ENABLED=false
#   EXPO_PUBLIC_AI_V5_AUTOMATIC_VERIFIED_BUNDLE_APPROVAL_ENABLED=false
#   AI_V5_EXACT_LOCALIZATION_APPROVAL_ENABLED=false
#
# Image generation (Supabase Edge secrets - see _shared/dalle-image.ts and _shared/ai-image-provider.ts allowlists):
#   OPENAI_IMAGE_MODEL_DEFAULT=gpt-image-1
#   OPENAI_IMAGE_MODEL_GENERATE=gpt-image-1
#   OPENAI_IMAGE_MODEL_EDIT=gpt-image-1
#   AI_IMAGE_PROVIDER=openai
#   AI_IMAGE_FALLBACK_PROVIDER=openai
#   AI_IMAGE_GEMINI_ENABLED=false
#   GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
#   GEMINI_IMAGE_ESTIMATED_COST_1K_USD=0.067
#   AI_IMAGE_OWNER_PHOTO_REFERENCE_ENABLED=true
#   AI_IMAGE_STOCK_FALLBACK_ENABLED=true
#
# Edge functions used by the app (deploy all that exist in `supabase/functions/`):
#   claim-deal, redeem-token, begin-visual-redeem, complete-visual-redeem, cancel-visual-redeem,
#   finalize-stale-redeems, delete-user-account, ingest-analytics-event, …
#
# Edge functions used by the app (representative; see `supabase/config.toml` and deploy all in use):
#   ai-compose-offer        — AI compose + optional voice (uses same OPENAI_MODEL for chat)
#   ai-generate-ad-variants — single-ad pipeline (research → copy → image; photo and/or hint)
#   ai-extract-menu         — menu photo → items (OpenAI Responses API + vision)
#   ai-business-lookup      — Google Places + optional AI estimate
#   ai-generate-deal-copy   — text deal copy suggestions
#   ai-create-deal          — legacy one-shot insert (dev-only / secondary)
#   Plus claim/redeem, analytics, billing/Stripe helpers, push, account deletion, etc.
